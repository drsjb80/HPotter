# HPotter Database Configuration
# Copy this file to .env and fill in your actual values
# Environment variables take precedence over config.yml

# Database type: 'sqlite' or 'postgresql'
DB_TYPE=postgresql

# Database name
DB_NAME=hpotter

# PostgreSQL credentials (only needed if DB_TYPE=postgresql)
DB_USER=hpotter
DB_PASSWORD=your_password_here
DB_HOST=your_postgres_host.rds.amazonaws.com
DB_PORT=5432
